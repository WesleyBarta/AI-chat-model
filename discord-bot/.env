# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# NexusMind API URL (NexusMind server must be running)
NEXUSMIND_URL=http://localhost:3000/api/chat

# Ollama model to use
OLLAMA_MODEL=llama3.2

# Bot display name
BOT_NAME=NexusBot

# Command prefix (optional, bot also responds to @mentions)
PREFIX=!